NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Midtrans Payment Gateway (sign up: https://midtrans.com)
MIDTRANS_SERVER_KEY=SB-Mid-server-your-key-here
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key-here
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Resend Email Service (sign up: https://resend.com)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Zentra Host <onboarding@resend.dev>

# Supabase Service Role (untuk webhook bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
